# PetLog Backend Environment Variables
# Copy this file to .env and fill in your values

# ===================
# Required
# ===================

# Database - Get this from Zeabur
DATABASE_URL=postgresql://username:password@host:port/database

# JWT Secret - Generate a strong random key (use: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-super-secret-key-min-32-characters-here

# ===================
# Optional - AI Services
# ===================

# OpenAI (for pet image analysis) - RECOMMENDED
OPENAI_API_KEY=sk-your-openai-api-key

# Google Generative AI (alternative)
# GOOGLE_API_KEY=your-google-api-key

# ZhipuAI (Chinese AI service)
# ZHIPUAI_API_KEY=your-zhipuai-api-key

# ===================
# Development
# ===================

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19000,exp://localhost:8081
